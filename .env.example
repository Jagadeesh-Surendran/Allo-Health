DATABASE_URL=postgresql://user:password@localhost:5432/allo_inventory
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development
JWT_SECRET=changeme
IDEMPOTENCY_TTL=86400
# ── Postgres (Supabase or Neon) ─────────────────────────────────────────
DATABASE_URL=""
# ^ Pooled connection string (port 6543 on Supabase, ?pgbouncer=true)
# Used by Prisma Client at runtime (queries).
# PgBouncer-compatible: does NOT support DDL or migrations.

DIRECT_URL=""
# ^ Direct connection string (port 5432, no pooler)
# Used ONLY by Prisma Migrate (schema changes, introspection).
# Without this, `prisma migrate dev` fails with "prepared statement already exists"
# because PgBouncer mangles the migration protocol.

# ── Redis (Upstash) ──────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# ^ Get these from Upstash console → your database → REST API tab

# ── App ──────────────────────────────────────────────────────────────────
CRON_SECRET=""
# ^ Generate with: openssl rand -hex 32
# Used to authenticate /api/cron/* endpoints from Vercel Cron.

NEXT_PUBLIC_APP_URL=""
# ^ e.g. https://allo-inventory.vercel.app (no trailing slash)
# Used for constructing absolute URLs in server components.

RESERVATION_TTL_SECONDS="600"
# ^ How long a reservation holds stock (default: 10 minutes).
# Externalised so you can change it without a code deployment.
# Must be parseable as a positive integer.
