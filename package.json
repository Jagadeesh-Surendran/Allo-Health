{
  "name": "allo-inventory-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time inventory reservation system - monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate:dev": "pnpm --filter backend prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter backend prisma migrate deploy",
    "db:seed": "pnpm --filter backend prisma db seed"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
