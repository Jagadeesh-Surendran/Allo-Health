{
  "name": "allo-inventory-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time inventory reservation system - monorepo",
  "scripts": {
    "dev:frontend": "pnpm --filter @allo-inventory/frontend dev",
    "dev:backend": "pnpm --filter @allo-inventory/backend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:migrate:dev": "pnpm --filter @allo-inventory/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @allo-inventory/database migrate:deploy",
    "db:seed": "pnpm --filter @allo-inventory/database seed",
    "reset-stock": "pnpm --filter @allo-inventory/frontend reset-stock",
    "stress-test": "pnpm --filter @allo-inventory/frontend stress-test"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
